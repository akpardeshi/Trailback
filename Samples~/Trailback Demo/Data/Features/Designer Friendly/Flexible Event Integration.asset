  m_Script: {fileID: 11500000, guid: 662de8a6992c486fa87e377ee9253765, type: 3}
  m_Name: Flexible Event Integration
  m_EditorClassIdentifier: ModularForge.Trailback.Demo::ModularForge.Trailback.Demo.Features.FeatureDemoData
  featureName: Flexible Event Integration
  shortDescription: Support Inspector, bridge, and direct event subscription workflows.
  fullDescription: "Trailback supports multiple event integration approaches, allowing
    teams to choose the workflow that best fits their project and development style.\r\n\r\nSupported
    event workflows:\r\n\r\n\u2022 Inspector Event Subscription\r\n\u2022 Bridge
    Event Subscription\r\n\u2022 Direct Framework Subscription\r\n\r\nInspector workflows
    allow designers to react to navigation events without writing code.\r\n\r\nBridge-based
    workflows provide a clean abstraction layer between application systems and Trailback.\r\n\r\nDirect
    framework subscriptions remain available when a lightweight integration is preferred.\r\n\r\nThis
    flexibility allows Trailback to support rapid prototyping, designer-driven workflows,
    and architecture-focused production projects without forcing a single integration
    pattern."
  screenshots: []
  videoUrl: https://youtu.be/AgmuAj9C4iQ
  documentationUrl: https://github.com/akpardeshi/Trailback-Unity/#event-subscription-reference
