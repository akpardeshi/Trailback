  m_Script: {fileID: 11500000, guid: 662de8a6992c486fa87e377ee9253765, type: 3}
  m_Name: Navigation Blockers
  m_EditorClassIdentifier: Assembly-CSharp::Trailback.Demo.Features.Data.FeatureDemoData
  featureName: Navigation Blockers
  shortDescription: Prevent back navigation when a workflow requires user attention
    or confirmation.
  fullDescription: 'Navigation Blockers allow applications to temporarily disable
    back navigation when leaving the current UI state could cause problems or interrupt
    an important workflow.


    Common use cases include:


    * Confirmation Dialogs

    *
    Unsaved Changes

    * Critical Workflows

    * Modal Interactions


    When
    a blocker is active, Trailback prevents navigation from continuing until the
    blocker is removed. This helps ensure that important user actions, confirmations,
    and in-progress workflows are not accidentally dismissed through back navigation.


    Navigation
    Blockers are integrated directly into Trailback''s navigation system, providing
    a consistent way to control when navigation should be available across different
    areas of an application.'
  screenshots: []
  videoUrl: 
  documentationUrl: https://github.com/akpardeshi/Trailback/#adding-navigation-blockers
