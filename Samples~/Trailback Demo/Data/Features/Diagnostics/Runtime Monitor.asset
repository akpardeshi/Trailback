  m_Script: {fileID: 11500000, guid: 662de8a6992c486fa87e377ee9253765, type: 3}
  m_Name: Runtime Monitor
  m_EditorClassIdentifier: Assembly-CSharp::Trailback.Demo.Features.Data.FeatureDemoData
  featureName: Runtime Monitor
  shortDescription: Inspect navigation state, history, blockers, and category resolution
    in real time.
  fullDescription: "Trailback Runtime Monitor provides a live view of the framework's
    internal state while your application is running.\r\n\r\nMonitor:\r\n\r\n\u2022
    Current Navigation Entry\r\n\u2022 Previous Navigation Entry\r\n\u2022 Navigation
    Availability\r\n\u2022 Active Blockers\r\n\u2022 Block Reasons\r\n\u2022 History
    Statistics\r\n\u2022 Category Resolution\r\n\r\nThe monitor is designed for debugging,
    integration, QA testing, and validating navigation behavior without writing custom
    diagnostic tools.\r\n\r\nIdeal for verifying complex UI flows involving screens,
    popups, overlays, and navigation blockers."
  screenshots: []
  videoUrl: https://youtu.be/EURabjPkRlU
  documentationUrl: https://github.com/akpardeshi/Trailback/#runtime-monitor
  featureStatus: 0
  featureVersion:
    Major: 1
    Minor: 0
    Patch: 0
  featureImportance: 9
